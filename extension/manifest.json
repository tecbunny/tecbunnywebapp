{
  "manifest_version": 3,
  "name": "E-Commerce Product Scraper",
  "version": "1.0.0",
  "description": "Scrapes e-commerce product details and sends them to an external database.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
